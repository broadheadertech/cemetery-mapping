{
  "name": "cemetery-mapping",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:convex": "convex dev",
    "dev:all": "concurrently -n NEXT,CONVEX -c blue,green \"npm run dev\" \"npm run dev:convex\"",
    "build": "next build && npm run build:sw",
    "build:sw": "node scripts/build-sw.mjs",
    "start": "next start",
    "lint": "next lint --dir src --dir convex --dir scripts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium",
    "lighthouse": "lhci autorun",
    "analyze": "ANALYZE=true next build",
    "check:bundle-size": "node scripts/check-bundle-size.mjs",
    "check:adr-0007": "node scripts/check-adr-0007.js",
    "check:backups": "node scripts/check-backups.mjs"
  },
  "dependencies": {
    "@auth/core": "^0.37.4",
    "@aws-sdk/client-s3": "^3.1051.0",
    "@convex-dev/auth": "^0.0.81",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "convex": "^1.17.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.16.0",
    "next": "^15.1.0",
    "pdfkit": "^0.18.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.76.0",
    "tailwind-merge": "^3.6.0",
    "three": "^0.160.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@lhci/cli": "^0.14.0",
    "@next/bundle-analyzer": "^15.5.18",
    "@playwright/test": "^1.49.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^22.10.0",
    "@types/pdfkit": "^0.17.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.160.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^2.1.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "convex-test": "^0.0.35",
    "esbuild": "^0.27.0",
    "eslint": "^9.16.0",
    "eslint-config-next": "^15.1.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-local-rules": "^3.0.2",
    "jsdom": "^25.0.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
