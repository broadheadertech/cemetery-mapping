# cemetery-mapping — environment variables
#
# Copy this file to `.env.local` (gitignored) and fill in real values.
# For production / preview, set the same variables in Convex + Vercel
# env-var systems (`npx convex env set KEY value`).

# ─── Convex deployment ───────────────────────────────────────────────
# Provisioned deployment for this project: beaming-boar-935
#
# Two Convex URLs, used for different purposes:
#   - .convex.cloud — backend (queries, mutations, actions). Used by the
#     React client. Set automatically by `npx convex dev` on first run.
#   - .convex.site  — HTTP routes (webhooks registered in
#     `convex/http.ts`). External providers POST here. Convex generates
#     this from the same deployment name; no code reads CONVEX_SITE_URL
#     today, but it's the operational reference for webhook setup.
NEXT_PUBLIC_CONVEX_URL=https://beaming-boar-935.convex.cloud
CONVEX_DEPLOYMENT=dev:beaming-boar-935
CONVEX_SITE_URL=https://beaming-boar-935.convex.site

# Webhook URLs that external providers must POST to (operational note —
# no code reads these; they go in the provider dashboards):
#   GCash:           https://beaming-boar-935.convex.site/api/gcash-webhook
#   Maya:            https://beaming-boar-935.convex.site/api/maya-webhook
#   Card processor:  https://beaming-boar-935.convex.site/api/card-webhook
#   Email bounces:   https://beaming-boar-935.convex.site/api/email-bounce-webhook

# ─── Customer portal (Story 9.7/9.8 reminder body links) ────────────
# Public origin where the customer portal is served. Reminder emails
# embed `${PORTAL_URL}/portal/contracts/<id>` as the "settle" link.
PORTAL_URL=https://portal.apostlepaul.ph

# ─── First-admin bootstrap (Story 1.1) ──────────────────────────────
# There is NO seed mutation and NO seed env var. The first admin is
# created by SIGNING UP: the `afterUserCreatedOrUpdated` callback in
# `convex/auth.ts` auto-promotes the very first account to `admin` when
# the `userRoles` table is empty. Every later sign-up gets no role and
# must be granted access by an existing admin (staff-accounts screen).
# Procedure: deploy → open the app → sign up once with the operator's
# email/password → you are now admin. See docs/getting-started.md and
# docs/runbook.md § First-admin bootstrap.

# ─── Story 9.8 (email reminders via Resend) ─────────────────────────
# Resend API key + verified sender. The bounce webhook is HMAC-verified
# via EMAIL_WEBHOOK_SECRET — register the webhook URL above with Resend
# and copy the signing secret it emits here.
RESEND_API_KEY=
RESEND_FROM="Apostle Paul Memorial Park <office@apostlepaul.ph>"
EMAIL_WEBHOOK_SECRET=

# ─── Story 3.13 (receipt email) ─────────────────────────────────────
# Receipt-issuance emails share the Resend tenant but use a distinct
# from-address so customers can filter receipts vs. reminders.
RECEIPT_EMAIL_FROM="Apostle Paul Memorial Park <receipts@apostlepaul.ph>"

# ─── Story 9.5 / 9.6 (portal payment gateways) ──────────────────────
# Per-gateway API base URLs are MANDATORY in production — adapters
# throw a configuration error rather than fall through to the dev mock.
# Webhook secrets are HMAC-shared with each gateway provider.
GCASH_API_BASE_URL=
GCASH_API_KEY=
GCASH_WEBHOOK_SECRET=

MAYA_API_BASE_URL=
MAYA_API_KEY=
MAYA_WEBHOOK_SECRET=

CARD_API_BASE_URL=
CARD_API_KEY=
CARD_WEBHOOK_SECRET=

# ─── Story 5.7 (archival export, optional S3 mirror) ────────────────
# Opt-in: when unset, the monthly archival action writes the gzip blob
# to Convex File Storage only. Setting these enables a parallel mirror
# to any S3-compatible bucket (AWS S3, Cloudflare R2, Backblaze B2,
# Wasabi). The bucket-side 10-year lifecycle policy lives in the
# bucket's console, not in this codebase — see docs/runbook.md.
ARCHIVE_S3_BUCKET=
ARCHIVE_S3_REGION=
ARCHIVE_S3_ACCESS_KEY=
ARCHIVE_S3_SECRET_KEY=
ARCHIVE_S3_ENDPOINT=

# ─── Story 9.7 (SMS reminders) — DEFERRED TO PHASE 2 ────────────────
# Removed 2026-05-22. The cemetery elected to ship email-only in
# Phase 1; Twilio was the previous provider but a PH-local provider
# (Semaphore / Movider / Globe Labs) will be selected when Story 9.7
# is re-opened. See _bmad-output/planning-artifacts/client-decisions-defaults.md Q12.
